# Release exclude gate for Zen Addons (consumed by scripts/build-plugin-release.sh).
# Keep the WordPress.org zip dev-free, AI-free, and strategy-free.
# NOTE: do NOT exclude *.less or compiled *.css — SiteOrigin needs them at runtime.
# Mirrors the FeedProof for WooCommerce release conventions.

# This file itself
.distignore

# Release build artifacts (never ship the zip inside the zip)
for-release/

# VCS / dev tooling
.git
.gitignore
.gitattributes
.editorconfig
.travis.yml
.circleci/
.github/
node_modules/

# AI assistant, strategy, and planning docs
CLAUDE.md
WORKSPACE-SETUP.md
AGENTS.md
SPEC.md
MILESTONE-*.md
ROADMAP-*.md
*-strategy.md
*strategy*.md
*.prompt.md
*.instructions.md
*.agent.md
.cursor/
.cursorrules
.aider*
.claude/

# Dev documentation (WordPress.org uses readme.txt, not these)
README.md
readme.md
docs/

# PHP / JS tooling and manifests
composer.json
composer.lock
phpcs.xml
phpcs.xml.dist
phpstan.neon
phpunit.xml
phpunit.xml.dist
package.json
package-lock.json
yarn.lock
gulpfile.js

# Source/build artifacts (compiled .css ships; sources + maps do not)
*.scss
*.css.map

# Dev scripts, tests, build, logs
scripts/
tests/
Makefile
*.sh
*.log

# WP.org listing screenshot staging (not shipped in the plugin)
.screenshots/
.screenshots

# Local-only design-picker planning doc (not shipped)
TODO-unified-design-picker.md
